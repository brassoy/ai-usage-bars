{
  "extension_name": { "message": "AI Usage Bars — for Claude.ai" },
  "extension_description": { "message": "Полоски использования на панели инструментов для сессии Claude.ai и недельных лимитов. Неофициальное, ваши данные не покидают браузер." },
  "star_on_github": { "message": "⭐ Звезда на GitHub" },
