  "settings": { "message": "Настройки" },
  "no_data_yet": { "message": "Нет данных" },
  "provider_no_data": { "message": "Нет данных — ожидание первого запроса." },
  "updated_ago": {
    "message": "Обновлено $RELATIVE$",
    "placeholders": { "relative": { "content": "$1" } }
  },
  "just_now": { "message": "только что" },
  "seconds_ago": {
    "message": "$N$ сек. назад",
    "placeholders": { "n": { "content": "$1" } }
  },
  "minutes_ago": {
    "message": "$N$ мин. назад",
    "placeholders": { "n": { "content": "$1" } }
  },
  "hours_ago": {
    "message": "$N$ ч. назад",
    "placeholders": { "n": { "content": "$1" } }
  },
  "not_signed_in": { "message": "Вход не выполнен." },
  "open_provider": {
    "message": "Открыть $NAME$",
    "placeholders": { "name": { "content": "$1" } }
  },
  "session_5h": { "message": "Сессия (5ч)" },
  "weekly": { "message": "Неделя" },
  "session_in": {
    "message": "сессия через $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "weekly_in": {
    "message": "неделя через $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "time_now": { "message": "сейчас" },
  "time_m": {
    "message": "$N$ мин",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h": {
    "message": "$N$ ч",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h_m": {
    "message": "$H$ ч $M$ мин",
    "placeholders": { "h": { "content": "$1" }, "m": { "content": "$2" } }
  },
  "time_d": {
    "message": "$N$ д",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_d_h": {
    "message": "$D$ д $H$ ч",
    "placeholders": { "d": { "content": "$1" }, "h": { "content": "$2" } }
  },
  "tooltip_waiting": { "message": "Использование — ожидание данных" },
  "tooltip_format": {
    "message": "$NAME$ — сессия $S$% · неделя $W$%",
    "placeholders": {
      "name": { "content": "$1" },
      "s": { "content": "$2" },
      "w": { "content": "$3" }
    }
  },
  "tooltip_sign_in": {
    "message": "$NAME$ — войдите на $URL$",
    "placeholders": {
      "name": { "content": "$1" },
      "url": { "content": "$2" }
    }
  },
  "options_title": { "message": "Настройки" },
  "options_interval_label": { "message": "Интервал обновления" },
  "options_interval_hint": { "message": "Как часто запрашивать данные Claude." },
  "options_interval_1": { "message": "Каждую 1 минуту" },
  "options_interval_5": { "message": "Каждые 5 минут" },
  "options_interval_15": { "message": "Каждые 15 минут" },
