  "provider_no_data": { "message": "Noch keine Daten — warte auf ersten Abruf." },
  "updated_ago": {
    "message": "Aktualisiert $RELATIVE$",
    "placeholders": { "relative": { "content": "$1" } }
  },
  "just_now": { "message": "gerade eben" },
  "seconds_ago": {
    "message": "vor $N$s",
    "placeholders": { "n": { "content": "$1" } }
  },
  "minutes_ago": {
    "message": "vor $N$m",
    "placeholders": { "n": { "content": "$1" } }
  },
  "hours_ago": {
    "message": "vor $N$h",
    "placeholders": { "n": { "content": "$1" } }
  },
  "not_signed_in": { "message": "Nicht angemeldet." },
  "open_provider": {
    "message": "$NAME$ öffnen",
    "placeholders": { "name": { "content": "$1" } }
  },
  "session_5h": { "message": "Sitzung (5h)" },
  "weekly": { "message": "Wöchentlich" },
  "session_in": {
    "message": "Sitzung in $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "weekly_in": {
    "message": "Woche in $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "time_now": { "message": "jetzt" },
  "time_m": {
    "message": "$N$m",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h": {
    "message": "$N$h",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h_m": {
    "message": "$H$h $M$m",
    "placeholders": { "h": { "content": "$1" }, "m": { "content": "$2" } }
  },
  "time_d": {
    "message": "$N$T",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_d_h": {
    "message": "$D$T $H$h",
    "placeholders": { "d": { "content": "$1" }, "h": { "content": "$2" } }
  },
  "tooltip_waiting": { "message": "Nutzung — warte auf Daten" },
  "tooltip_format": {
    "message": "$NAME$ — Sitzung $S$% · Woche $W$%",
    "placeholders": {
      "name": { "content": "$1" },
      "s": { "content": "$2" },
      "w": { "content": "$3" }
    }
  },
  "tooltip_sign_in": {
    "message": "$NAME$ — bei $URL$ anmelden",
    "placeholders": {
      "name": { "content": "$1" },
      "url": { "content": "$2" }
    }
  },
  "options_title": { "message": "Einstellungen" },
  "options_interval_label": { "message": "Aktualisierungsintervall" },
