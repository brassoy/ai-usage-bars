{
  "extension_name": { "message": "AI Usage Bars — for Claude.ai" },
  "extension_description": { "message": "Nutzungsbalken in der Symbolleiste für deine Claude.ai-Sitzung und wöchentliche Limits. Inoffiziell, deine Daten bleiben im Browser." },
  "star_on_github": { "message": "⭐ Auf GitHub starren" },
