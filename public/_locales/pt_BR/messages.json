  "weekly": { "message": "Semanal" },
  "session_in": {
    "message": "sessão em $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "weekly_in": {
    "message": "semanal em $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "time_now": { "message": "agora" },
  "time_m": {
    "message": "$N$m",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h": {
    "message": "$N$h",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h_m": {
    "message": "$H$h $M$m",
    "placeholders": { "h": { "content": "$1" }, "m": { "content": "$2" } }
