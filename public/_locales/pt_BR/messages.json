  "minutes_ago": {
    "message": "há $N$m",
    "placeholders": { "n": { "content": "$1" } }
  },
  "hours_ago": {
    "message": "há $N$h",
    "placeholders": { "n": { "content": "$1" } }
  },
  "not_signed_in": { "message": "Não conectado." },
  "open_provider": {
    "message": "Abrir $NAME$",
    "placeholders": { "name": { "content": "$1" } }
  },
