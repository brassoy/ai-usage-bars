{
  "extension_name": { "message": "AI Usage Bars — for Claude.ai" },
  "extension_description": { "message": "Barre di utilizzo nella barra degli strumenti per la tua sessione Claude.ai e i limiti settimanali. Non ufficiale, i tuoi dati restano nel browser." },
  "star_on_github": { "message": "⭐ Stella su GitHub" },
  "popup_title": { "message": "Utilizzo" },
  "refresh": { "message": "Aggiorna" },
  "settings": { "message": "Impostazioni" },
  "no_data_yet": { "message": "Nessun dato" },
  "provider_no_data": { "message": "Nessun dato — in attesa del primo recupero." },
  "updated_ago": {
    "message": "Aggiornato $RELATIVE$",
    "placeholders": { "relative": { "content": "$1" } }
  },
  "just_now": { "message": "adesso" },
  "seconds_ago": {
    "message": "$N$s fa",
    "placeholders": { "n": { "content": "$1" } }
  },
  "minutes_ago": {
    "message": "$N$m fa",
    "placeholders": { "n": { "content": "$1" } }
  },
  "hours_ago": {
    "message": "$N$h fa",
    "placeholders": { "n": { "content": "$1" } }
  },
  "not_signed_in": { "message": "Non hai effettuato l'accesso." },
  "open_provider": {
    "message": "Apri $NAME$",
    "placeholders": { "name": { "content": "$1" } }
  },
  "session_5h": { "message": "Sessione (5h)" },
  "weekly": { "message": "Settimanale" },
  "session_in": {
    "message": "sessione fra $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "weekly_in": {
    "message": "settimana fra $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "time_now": { "message": "ora" },
  "time_m": {
    "message": "$N$m",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h": {
    "message": "$N$h",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h_m": {
    "message": "$H$h $M$m",
    "placeholders": { "h": { "content": "$1" }, "m": { "content": "$2" } }
  },
  "time_d": {
    "message": "$N$g",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_d_h": {
    "message": "$D$g $H$h",
    "placeholders": { "d": { "content": "$1" }, "h": { "content": "$2" } }
  },
  "tooltip_waiting": { "message": "Utilizzo — in attesa dei dati" },
  "tooltip_format": {
    "message": "$NAME$ — sessione $S$% · settimana $W$%",
    "placeholders": {
      "name": { "content": "$1" },
      "s": { "content": "$2" },
      "w": { "content": "$3" }
    }
  },
  "tooltip_sign_in": {
    "message": "$NAME$ — accedi su $URL$",
    "placeholders": {
      "name": { "content": "$1" },
      "url": { "content": "$2" }
    }
  },
  "options_title": { "message": "Impostazioni" },
  "options_interval_label": { "message": "Intervallo di aggiornamento" },
  "options_interval_hint": { "message": "Ogni quanto consultare Claude." },
  "options_interval_1": { "message": "Ogni 1 minuto" },
  "options_interval_5": { "message": "Ogni 5 minuti" },
  "options_interval_15": { "message": "Ogni 15 minuti" },
  "options_saved": { "message": "Salvato." }
}
