{
  "extension_name": { "message": "AI Usage Bars — for Claude.ai" },
  "extension_description": { "message": "在工具栏上显示 Claude.ai 会话和每周限额的使用进度条。非官方,数据不离开浏览器。" },
  "star_on_github": { "message": "⭐ 在 GitHub 上加星" },
  "popup_title": { "message": "使用量" },
  "refresh": { "message": "刷新" },
  "settings": { "message": "设置" },
  "no_data_yet": { "message": "暂无数据" },
  "provider_no_data": { "message": "暂无数据 — 正在等待首次获取。" },
  "updated_ago": {
    "message": "更新于 $RELATIVE$",
    "placeholders": { "relative": { "content": "$1" } }
  },
  "just_now": { "message": "刚刚" },
  "seconds_ago": {
    "message": "$N$ 秒前",
    "placeholders": { "n": { "content": "$1" } }
  },
  "minutes_ago": {
    "message": "$N$ 分钟前",
    "placeholders": { "n": { "content": "$1" } }
  },
  "hours_ago": {
    "message": "$N$ 小时前",
    "placeholders": { "n": { "content": "$1" } }
  },
  "not_signed_in": { "message": "尚未登录。" },
  "open_provider": {
    "message": "打开 $NAME$",
    "placeholders": { "name": { "content": "$1" } }
  },
  "session_5h": { "message": "会话 (5小时)" },
  "weekly": { "message": "每周" },
  "session_in": {
    "message": "会话还剩 $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "weekly_in": {
    "message": "每周还剩 $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "time_now": { "message": "现在" },
  "time_m": {
    "message": "$N$ 分",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h": {
    "message": "$N$ 小时",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h_m": {
    "message": "$H$ 小时 $M$ 分",
    "placeholders": { "h": { "content": "$1" }, "m": { "content": "$2" } }
  },
  "time_d": {
    "message": "$N$ 天",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_d_h": {
    "message": "$D$ 天 $H$ 小时",
    "placeholders": { "d": { "content": "$1" }, "h": { "content": "$2" } }
  },
  "tooltip_waiting": { "message": "使用量 — 等待数据" },
  "tooltip_format": {
    "message": "$NAME$ — 会话 $S$% · 每周 $W$%",
    "placeholders": {
      "name": { "content": "$1" },
      "s": { "content": "$2" },
      "w": { "content": "$3" }
    }
  },
  "tooltip_sign_in": {
    "message": "$NAME$ — 请在 $URL$ 登录",
    "placeholders": {
      "name": { "content": "$1" },
      "url": { "content": "$2" }
    }
  },
  "options_title": { "message": "设置" },
  "options_interval_label": { "message": "刷新间隔" },
  "options_interval_hint": { "message": "查询 Claude 的频率。" },
  "options_interval_1": { "message": "每 1 分钟" },
  "options_interval_5": { "message": "每 5 分钟" },
  "options_interval_15": { "message": "每 15 分钟" },
  "options_saved": { "message": "已保存。" }
}
