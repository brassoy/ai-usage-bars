{
  "extension_name": { "message": "AI Usage Bars — for Claude.ai" },
  "extension_description": { "message": "Barras de uso en la barra de herramientas para tu sesión de Claude.ai y los límites semanales. No oficial, tus datos no salen del navegador." },
  "star_on_github": { "message": "⭐ Star en GitHub" },
  "popup_title": { "message": "Uso" },
  "refresh": { "message": "Actualizar" },
  "settings": { "message": "Ajustes" },
  "no_data_yet": { "message": "Sin datos" },
  "provider_no_data": { "message": "Sin datos aún — esperando primera consulta." },
  "updated_ago": {
    "message": "Actualizado $RELATIVE$",
    "placeholders": { "relative": { "content": "$1" } }
  },
  "just_now": { "message": "ahora mismo" },
  "seconds_ago": {
    "message": "hace $N$s",
    "placeholders": { "n": { "content": "$1" } }
  },
  "minutes_ago": {
    "message": "hace $N$m",
    "placeholders": { "n": { "content": "$1" } }
  },
  "hours_ago": {
    "message": "hace $N$h",
    "placeholders": { "n": { "content": "$1" } }
  },
  "not_signed_in": { "message": "Sesión no iniciada." },
  "open_provider": {
    "message": "Abrir $NAME$",
    "placeholders": { "name": { "content": "$1" } }
  },
  "session_5h": { "message": "Sesión (5h)" },
  "weekly": { "message": "Semanal" },
  "session_in": {
    "message": "sesión en $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "weekly_in": {
    "message": "semanal en $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "time_now": { "message": "ya" },
  "time_m": {
    "message": "$N$m",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h": {
    "message": "$N$h",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h_m": {
    "message": "$H$h $M$m",
    "placeholders": { "h": { "content": "$1" }, "m": { "content": "$2" } }
  },
  "time_d": {
    "message": "$N$d",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_d_h": {
    "message": "$D$d $H$h",
    "placeholders": { "d": { "content": "$1" }, "h": { "content": "$2" } }
  },
  "tooltip_waiting": { "message": "Uso — esperando datos" },
  "tooltip_format": {
    "message": "$NAME$ — sesión $S$% · semanal $W$%",
    "placeholders": {
      "name": { "content": "$1" },
      "s": { "content": "$2" },
      "w": { "content": "$3" }
    }
  },
  "tooltip_sign_in": {
    "message": "$NAME$ — iniciá sesión en $URL$",
    "placeholders": {
      "name": { "content": "$1" },
      "url": { "content": "$2" }
    }
  },
  "options_title": { "message": "Ajustes" },
  "options_interval_label": { "message": "Intervalo de actualización" },
  "options_interval_hint": { "message": "Cada cuánto se consulta el uso de Claude." },
  "options_interval_1": { "message": "Cada 1 minuto" },
  "options_interval_5": { "message": "Cada 5 minutos" },
  "options_interval_15": { "message": "Cada 15 minutos" },
  "options_saved": { "message": "Guardado." }
}
