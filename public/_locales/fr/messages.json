{
  "extension_name": { "message": "AI Usage Bars — for Claude.ai" },
  "extension_description": { "message": "Barres d'utilisation dans la barre d'outils pour votre session Claude.ai et les limites hebdomadaires. Non officiel, vos données ne quittent pas le navigateur." },
  "star_on_github": { "message": "⭐ Étoile sur GitHub" },
