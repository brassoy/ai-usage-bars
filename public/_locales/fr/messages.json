  "provider_no_data": { "message": "Aucune donnée — en attente du premier appel." },
  "updated_ago": {
    "message": "Mis à jour $RELATIVE$",
    "placeholders": { "relative": { "content": "$1" } }
  },
  "just_now": { "message": "à l'instant" },
  "seconds_ago": {
    "message": "il y a $N$s",
    "placeholders": { "n": { "content": "$1" } }
  },
  "minutes_ago": {
    "message": "il y a $N$m",
    "placeholders": { "n": { "content": "$1" } }
  },
  "hours_ago": {
    "message": "il y a $N$h",
    "placeholders": { "n": { "content": "$1" } }
  },
  "not_signed_in": { "message": "Non connecté." },
  "open_provider": {
    "message": "Ouvrir $NAME$",
    "placeholders": { "name": { "content": "$1" } }
  },
  "session_5h": { "message": "Session (5h)" },
  "weekly": { "message": "Hebdomadaire" },
  "session_in": {
    "message": "session dans $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "weekly_in": {
    "message": "hebdo dans $UNTIL$",
    "placeholders": { "until": { "content": "$1" } }
  },
  "time_now": { "message": "maintenant" },
  "time_m": {
    "message": "$N$m",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h": {
    "message": "$N$h",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_h_m": {
    "message": "$H$h $M$m",
    "placeholders": { "h": { "content": "$1" }, "m": { "content": "$2" } }
  },
  "time_d": {
    "message": "$N$j",
    "placeholders": { "n": { "content": "$1" } }
  },
  "time_d_h": {
    "message": "$D$j $H$h",
    "placeholders": { "d": { "content": "$1" }, "h": { "content": "$2" } }
  },
  "tooltip_waiting": { "message": "Usage — en attente de données" },
  "tooltip_format": {
    "message": "$NAME$ — session $S$% · hebdo $W$%",
    "placeholders": {
      "name": { "content": "$1" },
      "s": { "content": "$2" },
      "w": { "content": "$3" }
    }
  },
  "tooltip_sign_in": {
    "message": "$NAME$ — connectez-vous sur $URL$",
    "placeholders": {
      "name": { "content": "$1" },
      "url": { "content": "$2" }
    }
  },
  "options_title": { "message": "Paramètres" },
  "options_interval_label": { "message": "Intervalle d'actualisation" },
  "options_interval_hint": { "message": "Fréquence d'interrogation de Claude." },
